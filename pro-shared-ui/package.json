{
  "name": "@logosforge/pro-shared-ui",
  "version": "0.1.0",
  "private": true,
  "description": "LogosForge Studio (Pro) shared React UI — a dockable, cinematic writing workstation over the logosforge core. Platform-neutral; consumed by pro-desktop (Electron) and pro-web (browser). Owns the Studio visual identity. Never shares UI with the Whiteboard (Free) line.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "preview:dev": "vite --config preview/vite.config.ts"
  },
  "peerDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "dependencies": {
    "@logosforge/ui-contracts": "file:../logosforge-ui-contracts",
    "@tiptap/core": "^2.27.2",
    "@tiptap/extension-placeholder": "^2.27.2",
    "@tiptap/pm": "^2.27.2",
    "@tiptap/react": "^2.27.2",
    "@tiptap/starter-kit": "^2.27.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.21"
  }
}
