{
  "name": "logosforge-whiteboard-desktop",
  "version": "0.1.3",
  "private": true,
  "description": "LogosForge Whiteboard — Electron + React + TypeScript desktop shell",
  "author": "LogosForge",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite renderer",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && nodemon --watch electron --ext ts --exec \"npm run build:electron && electron .\"",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build renderer",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "npm run build && electron . --prod",
    "typecheck": "tsc -p tsconfig.electron.json --noEmit && tsc -p renderer/tsconfig.json --noEmit",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "test": "npm run typecheck && npm run test:screenplay && npm run test:paginate && npm run test:editor-tools && npm run test:files && npm run test:themes && npm run test:outline && npm run test:comments && npm run test:import-export && npm run test:littleboy && npm run test:gn && npm run test:stage",
    "test:screenplay": "esbuild renderer/src/features/screenplay/screenplayTests.ts --bundle --format=esm --platform=node --log-level=error --outfile=dist/screenplay-test.mjs && node dist/screenplay-test.mjs",
    "test:paginate": "esbuild renderer/src/features/screenplay/screenplayPaginateTests.ts --bundle --format=esm --platform=node --log-level=error --outfile=dist/paginate-test.mjs && node dist/paginate-test.mjs",
    "test:gn": "esbuild renderer/src/features/graphicNovel/graphicNovelTests.ts --bundle --format=esm --platform=node --log-level=error --outfile=dist/gn-test.mjs && node dist/gn-test.mjs",
    "test:stage": "esbuild renderer/src/features/stage/stageTests.ts --bundle --format=esm --platform=node --log-level=error --outfile=dist/stage-test.mjs && node dist/stage-test.mjs",
    "test:editor-tools": "esbuild renderer/src/features/editorTools/editorToolsTests.ts --bundle --format=esm --platform=node --log-level=error --outfile=dist/editor-tools-test.mjs && node dist/editor-tools-test.mjs",
    "test:files": "esbuild renderer/src/features/files/filesTests.ts --bundle --format=esm --platform=node --log-level=error --outfile=dist/files-test.mjs && node dist/files-test.mjs",
    "test:themes": "esbuild renderer/src/styles/themes/themesTests.ts --bundle --format=esm --platform=node --log-level=error --outfile=dist/themes-test.mjs && node dist/themes-test.mjs",
    "test:outline": "esbuild renderer/src/features/outline/outlineTests.ts --bundle --format=esm --platform=node --log-level=error --outfile=dist/outline-test.mjs && node dist/outline-test.mjs",
    "test:comments": "esbuild renderer/src/features/comments/commentsAnchorTests.ts --bundle --format=esm --platform=node --log-level=error --outfile=dist/comments-test.mjs && node dist/comments-test.mjs",
    "test:import-export": "esbuild renderer/src/features/files/importExportTests.ts --bundle --format=esm --platform=node --log-level=error --outfile=dist/import-export-test.mjs && node dist/import-export-test.mjs",
    "test:littleboy": "esbuild renderer/src/features/littleboy/littleboyTests.ts --bundle --format=esm --platform=node --log-level=error --outfile=dist/littleboy-test.mjs && node dist/littleboy-test.mjs",
    "smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "@tiptap/extension-placeholder": "^2.6.6",
    "@tiptap/pm": "^2.6.6",
    "@tiptap/react": "^2.6.6",
    "@tiptap/starter-kit": "^2.6.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^31.3.1",
    "electron-builder": "^25.1.8",
    "nodemon": "^3.1.7",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "wait-on": "^8.0.1"
  }
}
